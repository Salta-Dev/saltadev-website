DJANGO_SETTINGS_MODULE=saltadev.settings.production
SECRET_KEY=change-me
ALLOWED_HOSTS=salta.dev
CSRF_TRUSTED_ORIGINS=https://salta.dev

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.sa-east-1.aws.neon.tech/saltadev?sslmode=require

# Redis (Upstash) - nota: rediss:// (doble s) para TLS
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# Celery
CELERY_TASK_ALWAYS_EAGER=True

# Email (Resend HTTP API)
RESEND_API_KEY=re_xxx
DEFAULT_FROM_EMAIL=noreply@salta.dev

# reCAPTCHA v2
RECAPTCHA_V2_SITE_KEY=change-me
RECAPTCHA_V2_SECRET=change-me

# Site
SITE_URL=https://salta.dev
SITE_DOMAIN=salta.dev
SITE_NAME=SaltaDev

# Cloudinary
CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me

# Google OAuth
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
